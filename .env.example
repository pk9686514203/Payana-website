# ============================================
# MongoDB Connection (REQUIRED)
# ============================================
# Primary variable name (recommended):
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/payana-travel-hub?retryWrites=true&w=majority

# Alternative (for backward compatibility):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/payana-travel-hub?retryWrites=true&w=majority

# For Local Development:
# MONGO_URI=mongodb://localhost:27017/payana-travel-hub

# Connection String Format for MongoDB Atlas:
# mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/<database-name>?retryWrites=true&w=majority

# ============================================
# JWT Secret (REQUIRED)
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# ============================================
# Server Configuration
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# Frontend URLs (for CORS)
# ============================================
FRONTEND_DEV_URL=http://localhost:5173
FRONTEND_PRODUCTION_URL=https://your-site.netlify.app

# ============================================
# Optional: Cloudinary (Image Uploads)
# ============================================
# CLOUDINARY_NAME=your_cloudinary_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# Optional: Email Service
# ============================================
# SMTP_HOST=your_smtp_host
# SMTP_PORT=587
# SMTP_USER=your_email
# SMTP_PASSWORD=your_password
# SMTP_FROM=noreply@payana.com

