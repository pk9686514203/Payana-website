# ============================================
# MongoDB Connection (REQUIRED on Render)
# ============================================
# Use MONGO_URI (Render). Database name is forced to payanaDB in code (dbName option).
# Path in URI is optional; app always uses database: payanaDB
#
# Atlas SRV (default from Atlas UI):
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
#
# If you see querySrv ECONNREFUSED on Render:
# - Atlas → Network Access → allow 0.0.0.0/0 (or Render outbound IPs)
# - Try "Standard connection string" (non-SRV) from Atlas → Drivers
# - Code uses IPv4 (family: 4) to reduce DNS/SRV issues
#
# Optional tuning (ms):
# MONGO_SERVER_SELECTION_MS=30000
# MONGO_SOCKET_MS=120000
# MONGO_CONNECT_MS=30000
# MONGO_RETRY_MS=10000
#
# Alternative env name:
# MONGODB_URI=same_as_above

# For Local Development:
# MONGO_URI=mongodb://127.0.0.1:27017/?directConnection=true

# ============================================
# JWT Secret (REQUIRED)
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# ============================================
# Server Configuration
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# Frontend URLs (for CORS allowlist)
# ============================================
FRONTEND_DEV_URL=http://localhost:5173
FRONTEND_PRODUCTION_URL=https://payana-frontendd.vercel.app
# Any https://*.vercel.app is allowed automatically (preview + production).
# Emergency debug only (allows any browser origin — do not use in public production):
# CORS_ALLOW_ALL=true

# ============================================
# Optional: Cloudinary (Image Uploads)
# ============================================
# CLOUDINARY_NAME=your_cloudinary_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# Internal export / bookings list (keep secret)
# ============================================
EXPORT_SECRET=change_me_long_random_string
# Optional alias:
# INTERNAL_API_KEY=same_as_export_secret

# ============================================
# OTP SMS — Twilio (recommended) or Fast2SMS
# ============================================
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# FAST2SMS_API_KEY=
# FAST2SMS_ROUTE=otp

# ============================================
# Optional: Email Service
# ============================================
# SMTP_HOST=your_smtp_host
# SMTP_PORT=587
# SMTP_USER=your_email
# SMTP_PASSWORD=your_password
# SMTP_FROM=noreply@payana.com

